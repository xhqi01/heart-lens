# SQLite database file (relative to the prisma/ directory)
DATABASE_URL="file:./data/heartlens.db"

# Session signing secret — generate with: openssl rand -base64 48
AUTH_SECRET="replace-with-a-long-random-string"

# API-key encryption master key — must be 32 bytes, base64-encoded.
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY="replace-with-base64-encoded-32-byte-key"

# Account creation policy: "invite" (admin/script only) or "open" (public signup)
REGISTRATION_MODE="invite"
