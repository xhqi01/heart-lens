// HeartLens v2 — multi-tenant, self-hosted. SQLite single-file database.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  isAdmin      Boolean         @default(false)
  createdAt    DateTime        @default(now())
  config       ProviderConfig?
  archives     Archive[]
}

// One active BYOK provider config per user. API key stored encrypted (AES-256-GCM).
model ProviderConfig {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider         String // "anthropic" | "openai"
  baseUrl          String
  model            String
  apiKeyCiphertext String
  apiKeyIv         String
  apiKeyTag        String
  updatedAt        DateTime @updatedAt
}

model Archive {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  theirName String?
  context   String?
  mbti       String? // optional manual tag, e.g. "ISFP"
  attachment String? // "secure" | "anxious" | "avoidant" | "disorganized" | "unknown"
  traits     String? // comma-separated free-form trait tags
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  messages  Message[]
  journal   JournalEntry[]
  analyses  Analysis[]

  @@index([userId])
}

model Message {
  id         String   @id @default(cuid())
  archiveId  String
  archive    Archive  @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  sender     String // "me" | "them"
  senderName String?
  content    String
  timestamp  DateTime
  source     String   @default("manual") // "manual" | "instagram" | "whatsapp"

  @@index([archiveId])
}

model JournalEntry {
  id        String   @id @default(cuid())
  archiveId String
  archive   Archive  @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  text      String
  tags      String? // comma-separated
  type      String   @default("text") // "text" | "voice"
  createdAt DateTime @default(now())

  @@index([archiveId])
}

// Cached latest analysis result (raw JSON string).
model Analysis {
  id        String   @id @default(cuid())
  archiveId String
  archive   Archive  @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  json      String
  createdAt DateTime @default(now())

  @@index([archiveId])
}
